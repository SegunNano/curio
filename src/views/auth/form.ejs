<% layout('/layouts/boilerplate') %>

<div class="max-w-md mx-auto px-6 py-16">

  <!-- Tabs -->
  <div class="flex border-b border-gray-200 dark:border-gray-800 mb-8">
    <a href="/auth?type=signup"
      class="pb-3 px-4 text-sm font-medium <%= type === 'signup' ? 'border-b-2 border-gray-900 dark:border-white' : 'text-gray-400' %>">
      Sign Up
    </a>
    <a href="/auth?type=login"
      class="pb-3 px-4 text-sm font-medium <%= type === 'login' ? 'border-b-2 border-gray-900 dark:border-white' : 'text-gray-400' %>">
      Login
    </a>
  </div>

  <% if (type === 'signup') { %>

    <!-- Signup Form -->
    <form action="/auth/signup" method="POST" class="space-y-4">

      <div>
        <label class="block text-sm font-medium mb-1">Full Name</label>
        <input type="text" name="name" required placeholder="John Doe"
          class="w-full px-4 py-2 border border-gray-200 dark:border-gray-700 rounded-lg bg-transparent focus:outline-none focus:ring-2 focus:ring-gray-900 dark:focus:ring-white"/>
      </div>

      <div>
        <label class="block text-sm font-medium mb-1">Email</label>
        <input type="email" name="email" required placeholder="john@example.com"
          class="w-full px-4 py-2 border border-gray-200 dark:border-gray-700 rounded-lg bg-transparent focus:outline-none focus:ring-2 focus:ring-gray-900 dark:focus:ring-white"/>
      </div>

      <div>
        <label class="block text-sm font-medium mb-1">Password</label>
        <input type="password" name="password" required placeholder="••••••••"
          class="w-full px-4 py-2 border border-gray-200 dark:border-gray-700 rounded-lg bg-transparent focus:outline-none focus:ring-2 focus:ring-gray-900 dark:focus:ring-white"/>
      </div>

      <!-- Categories -->
      <div>
        <label class="block text-sm font-medium mb-2">News Categories</label>
        <div class="grid grid-cols-3 gap-2">
          <% categories.forEach(cat => { %>
            <label class="flex items-center gap-2 text-sm cursor-pointer">
              <input type="checkbox" name="categories" value="<%= cat %>"
                <%= cat === 'technology' ? 'checked' : '' %>
                class="rounded"/>
              <%= cat.charAt(0).toUpperCase() + cat.slice(1) %>
            </label>
          <% }) %>
        </div>
      </div>

      <!-- Digest Frequency -->
      <div>
        <label class="block text-sm font-medium mb-1">
          Digest Frequency (every how many days?)
        </label>
        <select name="digestFrequency"
          class="w-full px-4 py-2 border border-gray-200 dark:border-gray-700 rounded-lg bg-white dark:bg-gray-950 focus:outline-none">
          <% [1,2,3,4,5,6,7].forEach(n => { %>
            <option value="<%= n %>" <%= n === 3 ? 'selected' : '' %>>
              Every <%= n %> day<%= n > 1 ? 's' : '' %>
            </option>
          <% }) %>
        </select>
      </div>

      <button type="submit"
        class="w-full bg-gray-900 dark:bg-white text-white dark:text-gray-900 py-3 rounded-lg font-medium hover:opacity-90 transition">
        Create Account
      </button>

    </form>

  <% } else { %>

    <!-- Login Form -->
    <form action="/auth/login" method="POST" class="space-y-4">

      <div>
        <label class="block text-sm font-medium mb-1">Email</label>
        <input type="email" name="email" required placeholder="john@example.com"
          class="w-full px-4 py-2 border border-gray-200 dark:border-gray-700 rounded-lg bg-transparent focus:outline-none focus:ring-2 focus:ring-gray-900 dark:focus:ring-white"/>
      </div>

      <div>
        <label class="block text-sm font-medium mb-1">Password</label>
        <input type="password" name="password" required placeholder="••••••••"
          class="w-full px-4 py-2 border border-gray-200 dark:border-gray-700 rounded-lg bg-transparent focus:outline-none focus:ring-2 focus:ring-gray-900 dark:focus:ring-white"/>
      </div>

      <button type="submit"
        class="w-full bg-gray-900 dark:bg-white text-white dark:text-gray-900 py-3 rounded-lg font-medium hover:opacity-90 transition">
        Login
      </button>

    </form>

  <% } %>

</div>