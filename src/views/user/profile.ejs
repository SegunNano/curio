<% layout('layouts/boilerplate') %>

<div class="max-w-3xl mx-auto px-6 py-10">

  <!-- Header -->
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold">Profile</h1>
      <p class="text-gray-500 dark:text-gray-400 text-sm mt-1">
        Manage your account and preferences
      </p>
    </div>
    <button onclick="openModal()"
      class="text-sm bg-gray-900 dark:bg-white text-white dark:text-gray-900 px-4 py-2 rounded-lg hover:opacity-90 transition">
      ✏️ Edit Profile
    </button>
  </div>

  <!-- Profile Card -->
  <div class="border border-gray-200 dark:border-gray-800 rounded-xl p-6 mb-6">
    <div class="flex items-center gap-4 mb-6">

      <!-- Avatar -->
      <div class="w-14 h-14 rounded-full bg-gray-900 dark:bg-white flex items-center justify-center text-white dark:text-gray-900 text-xl font-bold">
        <%= currentUser.name.charAt(0).toUpperCase() %>
      </div>

      <div>
        <h2 class="font-semibold text-lg"><%= currentUser.name %></h2>
        <p class="text-gray-500 dark:text-gray-400 text-sm"><%= currentUser.email %></p>
      </div>

      <!-- Status Badge -->
      <div class="ml-auto">
        <% if (currentUser.status === 'active') { %>
          <span class="text-xs bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 px-3 py-1 rounded-full font-medium">
            ✅ Active
          </span>
        <% } else if (currentUser.status === 'unverified') { %>
          <span class="text-xs bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-400 px-3 py-1 rounded-full font-medium">
            ⚠️ Unverified
          </span>
        <% } else { %>
          <span class="text-xs bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400 px-3 py-1 rounded-full font-medium">
            🔴 Inactive
          </span>
        <% } %>
      </div>

    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 gap-4 pt-6 border-t border-gray-100 dark:border-gray-800">
      <div>
        <p class="text-xs text-gray-400 mb-1">Digest Frequency</p>
        <p class="font-medium text-sm">Every <%= currentUser.digestFrequency %> day<%= currentUser.digestFrequency > 1 ? 's' : '' %></p>
      </div>
      <div>
        <p class="text-xs text-gray-400 mb-1">Member Since</p>
        <p class="font-medium text-sm"><%= new Date(currentUser.createdAt).toLocaleDateString('en-US', { month: 'long', year: 'numeric' }) %></p>
      </div>
      <div>
        <p class="text-xs text-gray-400 mb-1">Last Active</p>
        <p class="font-medium text-sm"><%= new Date(currentUser.lastActiveAt).toLocaleDateString() %></p>
      </div>
      <div>
        <p class="text-xs text-gray-400 mb-1">Categories</p>
        <p class="font-medium text-sm"><%= currentUser.categories.length %> selected</p>
      </div>
    </div>

  </div>

  <!-- Categories Card -->
  <div class="border border-gray-200 dark:border-gray-800 rounded-xl p-6">
    <h3 class="font-semibold mb-4">Your Categories</h3>
    <div class="flex flex-wrap gap-2">
      <% currentUser.categories.forEach(cat => { %>
        <span class="px-3 py-1 bg-gray-100 dark:bg-gray-800 rounded-full text-sm capitalize">
          <%= cat %>
        </span>
      <% }) %>
    </div>
  </div>

  <!-- Unverified Banner -->
  <% if (currentUser.status === 'unverified') { %>
    <div class="flex items-center justify-between bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-800 text-yellow-800 dark:text-yellow-300 px-4 py-3 rounded-lg mt-6">
      <p class="text-sm">📧 Your email is not verified yet</p>
      <a href="/auth/resend-verification" class="text-sm underline font-medium">
        Resend verification
      </a>
    </div>
  <% } %>

</div>

<!-- Edit Modal -->
<div id="modal"
  class="fixed inset-0 bg-black/50 backdrop-blur-sm hidden items-center justify-center z-50">
  <div class="bg-white dark:bg-gray-900 rounded-2xl p-8 w-full max-w-lg mx-4 max-h-[90vh] overflow-y-auto">

    <div class="flex items-center justify-between mb-6">
      <h2 class="text-lg font-bold">Edit Profile</h2>
      <button onclick="closeModal()" class="text-gray-400 hover:text-gray-600">✕</button>
    </div>

    <form action="/user/profile" method="POST" class="space-y-5">

      <!-- Name -->
      <div>
        <label class="block text-sm font-medium mb-1">Full Name</label>
        <input type="text" name="name" value="<%= currentUser.name %>"
          class="w-full px-4 py-2 border border-gray-200 dark:border-gray-700 rounded-lg bg-transparent focus:outline-none focus:ring-2 focus:ring-gray-900 dark:focus:ring-white"/>
      </div>

      <!-- Digest Frequency -->
      <div>
        <label class="block text-sm font-medium mb-1">Digest Frequency</label>
        <select name="digestFrequency"
          class="w-full px-4 py-2 border border-gray-200 dark:border-gray-700 rounded-lg bg-white dark:bg-gray-900 focus:outline-none">
          <% [1,2,3,4,5,6,7].forEach(n => { %>
            <option value="<%= n %>"
              <%= currentUser.digestFrequency === n ? 'selected' : '' %>>
              Every <%= n %> day<%= n > 1 ? 's' : '' %>
            </option>
          <% }) %>
        </select>
      </div>

      <!-- Categories -->
      <div>
        <label class="block text-sm font-medium mb-2">Categories</label>
        <div class="grid grid-cols-2 gap-2">
          <% categories.forEach(cat => { %>
            <label class="flex items-center gap-2 text-sm cursor-pointer">
              <input type="checkbox" name="categories" value="<%= cat %>"
                <%= currentUser.categories.includes(cat) ? 'checked' : '' %>
                class="rounded"/>
              <%= cat.charAt(0).toUpperCase() + cat.slice(1) %>
            </label>
          <% }) %>
        </div>
      </div>

      <div class="flex gap-3 pt-2">
        <button type="submit"
          class="flex-1 bg-gray-900 dark:bg-white text-white dark:text-gray-900 py-2 rounded-lg font-medium hover:opacity-90 transition">
          Save Changes
        </button>
        <button type="button" onclick="closeModal()"
          class="flex-1 border border-gray-200 dark:border-gray-700 py-2 rounded-lg text-sm hover:bg-gray-50 dark:hover:bg-gray-900 transition">
          Cancel
        </button>
      </div>

    </form>
  </div>
</div>

<script>
  const modal = document.getElementById('modal')

  function openModal() {
    modal.classList.remove('hidden')
    modal.classList.add('flex')
  }

  function closeModal() {
    modal.classList.add('hidden')
    modal.classList.remove('flex')
  }

  // Close on backdrop click
  modal.addEventListener('click', (e) => {
    if (e.target === modal) closeModal()
  })
</script>
